<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        
        <p>Here are a few of our partner organizations:</p>
        <ul>

            <% organizations.forEach(organization => { %>
                <li>
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <a href="/organization/<%= organization.organization_id %>">
                    <strong><%= organization.name %></strong></a>: <%= organization.contact_email %>
                </li>
            <% }); %>
        </ul>

        <p>
            <% if (user && user.role_name === 'admin') { %>
            <a href="/new-organization">Add a new organization</a>
            <% } %>      
        </p>
    </main>

<%- include('partials/footer') %>