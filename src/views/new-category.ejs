<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <form action="/new-category" method="POST">

        <label for="name">
            Category Name
        </label>

        <input
            type="text"
            id="name"
            name="name"
            required
            maxlength="100"
        >

        <button type="submit">
            Create Category
        </button>

    </form>

</main>

<%- include('partials/footer') %>