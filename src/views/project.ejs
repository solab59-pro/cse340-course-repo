<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>

    <p>
        <strong>Description:</strong>
        <%= project.description %>
    </p>

    <p>
        <strong>Date:</strong>

        <%= new Date(project.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        }) %>
    </p>

    <p>
        <strong>Location:</strong>
        <%= project.location %>
    </p>

    <p>
        <strong>Organization:</strong>

        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <h3>Categories</h3>

    <ul>
        <% categories.forEach(category => { %>
            <li>
                <a href="/category/<%= category.category_id %>">
                    <%= category.name %>
                </a>
            </li>
        <% }); %>
    </ul>

    <p>
        <% if (user && user.role_name === 'admin') { %>
        <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
        <% } %>
    </p>
    <p>
        <% if (user && user.role_name === 'admin') { %>
        <a href="/edit-project/<%= project.project_id %>">Edit Project</a>
        <% } %>
    </p>

    <% if (user) { %>

        <% if (isVolunteering) { %>

            <p>You are volunteering for this project.</p>

            <form action="/project/<%= project.project_id %>/unvolunteer" method="POST">
            <button type="submit">Remove Me</button>
            </form>

        <% } else { %>

            <form action="/project/<%= project.project_id %>/volunteer" method="POST">
                <button type="submit">Volunteer for this Project</button>
            </form>

        <% } %>

    <% } %>

</main>

<%- include('partials/footer') %>